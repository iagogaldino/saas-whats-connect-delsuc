{
  "name": "whatsapp-otp-service",
  "version": "1.0.0",
  "description": "Microserviço REST para envio de OTP via WhatsApp (whatsapp-web.js)",
  "main": "dist/server.js",
  "scripts": {
    "dev": "nodemon --exec ts-node src/server.ts",
    "build": "tsc",
    "postinstall": "patch-package && node scripts/install-chrome.cjs",
    "clean:wwebjs": "node scripts/clean-wwebjs-session.cjs",
    "start": "node dist/server.js"
  },
  "keywords": [
    "whatsapp",
    "otp",
    "express",
    "typescript"
  ],
  "license": "ISC",
  "dependencies": {
    "@hapi/boom": "^10.0.1",
    "@whiskeysockets/baileys": "^6.7.18",
    "bcryptjs": "^2.4.3",
    "cors": "^2.8.5",
    "dotenv": "^16.4.5",
    "express": "^4.21.2",
    "jsonwebtoken": "^9.0.2",
    "mercadopago": "^2.12.0",
    "mongoose": "^8.9.5",
    "nodemailer": "^6.9.16",
    "pino": "^9.6.0",
    "qrcode-terminal": "^0.12.0",
    "socket.io": "^4.8.3",
    "zod": "^3.24.1"
  },
  "devDependencies": {
    "@types/bcryptjs": "^2.4.6",
    "@types/cors": "^2.8.17",
    "@types/express": "^4.17.21",
    "@types/jsonwebtoken": "^9.0.7",
    "@types/nodemailer": "^6.4.17",
    "@types/node": "^22.10.5",
    "@types/qrcode-terminal": "^0.12.2",
    "nodemon": "^3.1.9",
    "ts-node": "^10.9.2",
    "typescript": "^5.7.2"
  }
}
