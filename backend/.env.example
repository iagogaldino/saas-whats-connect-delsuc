PORT=3001
# Opcional em dev: se omitido, usa mongodb://127.0.0.1:27017/whatsapp_otp e JWT dev (ver server.ts)
# Com Docker no host: use Atlas/rede ou, para Mongo na máquina, algo como mongodb://host.docker.internal:27017/whatsapp_otp
MONGODB_URI=mongodb://127.0.0.1:27017/whatsapp_otp
JWT_SECRET=altere_para_um_segredo_longo_em_producao
JWT_EXPIRES_IN=7d
# Plano grátis: max. envios com sucesso por dia (UTC), contados em SentMessage. Paid: sem teto.
FREE_DAILY_SEND_LIMIT=20
# Duração (dias) de cada ativação do plano pago a partir da data de aprovação do pagamento (UTC).
PAID_PLAN_DURATION_DAYS=30
# Varredura periódica: utilizadores com plano pago expirado passam a grátis na BD (ms). 0 = desativar (só lazy em getUserPlan).
# Default 3600000 (1h). Mínimo 10s, máx. 7 dias.
# PLAN_EXPIRATION_SWEEP_INTERVAL_MS=3600000
# Fila (Mongo) de tarefas pós-ativação premium: reprocessa falhas no arranque; máximo de reenvios.
# PREMIUM_ACTIVATION_MAX_ATTEMPTS=10
#
# Mercado Pago (Checkout Pro / preferências) — nunca commite tokens reais.
# MERCADOPAGO_ACCESS_TOKEN=TEST-...
# MERCADOPAGO_PUBLIC_KEY=TEST-... (só documentação no back; no front use VITE_MERCADOPAGO_PUBLIC_KEY)
# URL do front para back_urls (ex.: http://localhost:5173 em dev) e ligação de recuperação de senha.
# FRONTEND_URL=http://localhost:5173
# Recuperação de senha (SMTP). Em produção, SMTP_HOST + MAIL_FROM são necessários; sem isso, o pedido falha.
# Em desenvolvimento sem SMTP, a ligação de redefinição é registada no log do servidor.
# PASSWORD_RESET_TOKEN_TTL_MINUTES=60
# SMTP_HOST=smtp.example.com
# SMTP_PORT=587
# SMTP_SECURE=0
# SMTP_USER=
# SMTP_PASS=
# MAIL_FROM="WhatsApp Connect <no-reply@example.com>"
# Base pública da API (HTTPS) para o Mercado Pago (webhook: cartão e PIX, notificações de pagamento).
# Se vazio, o PIX ainda funciona; o utilizador confirma por polling/«Verificar».
# API_PUBLIC_URL=https://seu-dominio.com
WWEBJS_DATA_PATH=./.wwebjs_auth
WWEBJS_CLIENT_ID=otp-service
# Dev: abre janela do Chrome ao parear (ver WhatsApp Web no ecrã). Produção: omitir ou 0.
# WWEBJS_SHOW_BROWSER=1
# Timeout (ms) para inject/auth no WhatsApp Web (default 120000).
# WWEBJS_AUTH_TIMEOUT_MS=120000
#
# Limpar sessão LocalAuth / perfil Chromium: pare o servidor e o Chrome do Puppeteer, depois: npm run clean:wwebjs
# CORS: não há lista fixa; a API aceita qualquer origem (origin dinâmico + credentials).
#
# Chrome para Puppeteer / whatsapp-web.js (ordem: PUPPETEER_EXECUTABLE_PATH → cache do Puppeteer → Chrome do sistema):
# - Recomendado: após npm install, rode `node scripts/install-chrome.cjs` para baixar o Chrome compatível com a lib.
# - Sem isso, o servidor usa o Chrome instalado no Windows/macOS/Linux (pode divergir da versão do Puppeteer).
# PUPPETEER_EXECUTABLE_PATH=C:\Program Files\Google\Chrome\Application\chrome.exe
#
# Deploy (ex.: Render): não defina PUPPETEER_SKIP_DOWNLOAD. O Chrome vai para ./.puppeteer-cache
# (mesmo caminho no build e no runtime; não use só o cache em ~/.cache).
# Opcional: caminho absoluto do cache do Puppeteer (deve bater com o do postinstall).
# PUPPETEER_CACHE_DIR=
